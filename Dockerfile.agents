FROM golang:1.22-alpine AS builder

WORKDIR /src/agents

COPY agents/go.mod ./
RUN go mod download

COPY agents/ ./

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /agents ./cmd/server

FROM gcr.io/distroless/static-debian12

COPY --from=builder /agents /agents

EXPOSE 8090

ENTRYPOINT ["/agents"]
