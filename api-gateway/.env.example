# ── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080
ENVIRONMENT=development

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>

# Found in: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Found in: Supabase Dashboard → Settings → API → service_role key
# Required for server-side report artifact upload to Supabase Storage.
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Optional report artifact bucket name (default: agentshield-reports)
SUPABASE_REPORTS_BUCKET=agentshield-reports

# Found in: Supabase Dashboard → Settings → Database → Connection string (Transaction Pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:29092
KAFKA_GROUP_ID=api-gateway-ws

# ── Orchestrator (set to true once orchestrator service is running) ───────────
ORCHESTRATOR_ENABLED=false
ORCHESTRATOR_ADDR=orchestrator:50051
AGENTS_SERVICE_URL=http://agents:8090
JUDGE_SERVICE_URL=http://judge:8091
ORCHESTRATOR_SCAN_STATUS_TOPIC=agent.status

# Optional service runtime modes (used by docker-compose)
AGENTS_EXECUTION_MODE=simulate
JUDGE_EVAL_MODE=rule
# Required only when JUDGE_EVAL_MODE=openai_compat
JUDGE_LLM_BASE_URL=
JUDGE_LLM_API_KEY=
JUDGE_LLM_MODEL=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000
