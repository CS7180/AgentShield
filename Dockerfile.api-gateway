FROM golang:1.22-alpine AS builder

WORKDIR /src/api-gateway

COPY api-gateway/go.mod api-gateway/go.sum ./
RUN go mod download

COPY api-gateway/ ./

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o /api-gateway ./cmd/server

FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=builder /api-gateway ./api-gateway
COPY --from=builder /src/api-gateway/migrations ./migrations

EXPOSE 8080

USER nobody

ENTRYPOINT ["./api-gateway"]
