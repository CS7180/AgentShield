{
  "allowedTools": [
    "Bash(go build ./...)",
    "Bash(go build ./cmd/server)",
    "Bash(go test ./...)",
    "Bash(go test -race -cover ./...)",
    "Bash(go test -v ./...)",
    "Bash(go test -v -race -cover ./...)",
    "Bash(go test -run * ./...)",
    "Bash(go test -v -run * ./...)",
    "Bash(go mod tidy)",
    "Bash(go mod download)",
    "Bash(go vet ./...)",
    "Bash(gofmt -l .)",
    "Bash(gofmt -w .)",
    "Bash(make build)",
    "Bash(make test)",
    "Bash(make lint)",
    "Bash(make proto)",
    "Bash(make tidy)",
    "Bash(make docker-up)",
    "Bash(make docker-down)",
    "Bash(docker compose up -d redis kafka zookeeper)",
    "Bash(docker compose down)",
    "Bash(docker compose build api-gateway)",
    "Bash(docker compose ps)",
    "Bash(docker compose logs *)",
    "Bash(pytest)",
    "Bash(pytest -v)",
    "Bash(pytest -v --cov=* --cov-report=term-missing)",
    "Bash(pytest -m *)",
    "Bash(ruff check .)",
    "Bash(ruff format .)",
    "Bash(black .)",
    "Bash(pip install -r requirements.txt)",
    "Bash(npm install)",
    "Bash(npm run lint)",
    "Bash(npm run build)",
    "Bash(npm test)",
    "Bash(npm test -- --coverage)",
    "Bash(git status)",
    "Bash(git diff)",
    "Bash(git diff *)",
    "Bash(git log)",
    "Bash(git log *)",
    "Bash(git add *)",
    "Bash(git commit *)",
    "Bash(git branch)",
    "Bash(git branch *)",
    "Bash(git checkout *)",
    "Bash(git stash)",
    "Bash(git stash pop)",
    "Bash(find . *)",
    "Bash(ls *)",
    "Bash(cat *)",
    "Bash(wc *)",
    "Bash(which *)",
    "Bash(go version)",
    "Bash(go env)"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'fp=$(python3 -c \"import os,json; print(json.loads(os.environ.get(\\\"CLAUDE_TOOL_INPUT\\\",\\\"{}\\\")).get(\\\"file_path\\\",\\\"\\\"))\" 2>/dev/null); if [[ \"$fp\" =~ /frontend/.*\\.jsx?$ ]]; then root=$(git -C \"$(dirname \"$fp\")\" rev-parse --show-toplevel 2>/dev/null); [[ -n \"$root\" ]] && cd \"$root/frontend\" && npm run lint --silent 2>&1 | head -20; fi'",
            "timeout": 15000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'root=$(git rev-parse --show-toplevel 2>/dev/null) && [[ -d \"$root/frontend\" ]] && cd \"$root/frontend\" && npm test 2>&1 | tail -8 || true'",
            "timeout": 60000
          }
        ]
      }
    ]
  }
}
